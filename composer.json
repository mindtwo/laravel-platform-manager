{
    "name": "mindtwo/laravel-platform-manager",
    "description": "A pacakage to resolve platforms.",
    "keywords": [
        "domains",
        "multidomain",
        "multisite",
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "homepage": "https://github.com/mindtwo/laravel-platform-manager",
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de",
            "homepage": "https://mindtwo.de"
        }
    ],
    "require": {
        "php": "^8.3||^8.4||^8.5",
        "laravel/framework": "^12.0",
        "chiiya/laravel-utilities": "^5.7"
    },
    "require-dev": {
        "laravel/pint": "^1.4",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "larastan/larastan": "^3.0",
        "barryvdh/laravel-ide-helper": "^3.6"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "mindtwo\\LaravelPlatformManager\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "mindtwo\\LaravelPlatformManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "mindtwo\\LaravelPlatformManager\\LaravelPlatformManagerProvider"
            ],
            "aliases": {}
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.packagist.com/mindtwo/"
        }
    ]
}
